# ── Your HyperLiquid Wallet ────────────────────────────────────
# Same wallet as your first copy bot is fine; this bot uses its own ratio/leverage.
HL_WALLET_ADDRESS=0xYOUR_WALLET_ADDRESS
HL_PRIVATE_KEY=0xYOUR_PRIVATE_KEY
# If using an agent wallet, set the account being traded:
# HL_ACCOUNT_ADDRESS=0xACCOUNT_ADDRESS

# ── Target Trader (second / larger account) ────────────────────
COPY_TARGET_ADDRESS=0xe3c97b18216f58af4b9c1347d0ee010c42e6a85d

# ── Scaling ────────────────────────────────────────────────────
#   "proportional"  – (your equity / their equity) * their delta
#   "fixed_ratio"   – their delta * ratio  (0.005 = 0.5% of their size)
#   "fixed_size"    – always trade COPY_FIXED_SIZE per signal
COPY_SCALING_MODE=fixed_ratio
COPY_FIXED_RATIO=0.005
# COPY_FIXED_SIZE=0.001

# ── Risk ───────────────────────────────────────────────────────
COPY_MAX_POSITION_USD=5000
COPY_LEVERAGE=10
COPY_IS_CROSS=false

# ── Execution ──────────────────────────────────────────────────
COPY_POLL_INTERVAL=3.0
COPY_SLIPPAGE_BPS=10.0
COPY_MIN_TRADE_USD=11.0

# ── Coins (BTC only for this target) ───────────────────────────
COPY_COINS=BTC

# ── Startup ────────────────────────────────────────────────────
COPY_SYNC_STARTUP=true

# ── Safety ─────────────────────────────────────────────────────
COPY_MAX_DAILY_TRADES=200
COPY_DRY_RUN=true

# ── Logging ────────────────────────────────────────────────────
COPY_LOG_LEVEL=INFO
